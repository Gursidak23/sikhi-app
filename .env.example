# ============================================================================
# SIKHI VIDHYA PLATFORM - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE (Aiven PostgreSQL - RECOMMENDED for production)
# =============================================================================
# Get your connection string from Aiven Console:
# https://console.aiven.io/ -> Your Service -> Overview -> Connection information
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
#
# Example (Aiven):
# DATABASE_URL="postgresql://avnadmin:YOUR_PASSWORD@pg-sikhi-vidhya-YOUR_PROJECT.aivencloud.com:12345/defaultdb?sslmode=require"
#
# Local development:
DATABASE_URL="postgresql://user:password@localhost:5432/sikhi_dev?sslmode=prefer"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# i18n (pa = Punjabi, en = English, hi = Hindi)
NEXT_PUBLIC_DEFAULT_LOCALE="pa"
